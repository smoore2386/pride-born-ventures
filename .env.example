# ─────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://prideborn.io

# ─────────────────────────────────────────────────────────────
# Firebase — client (public, exposed to the browser)
# For emulator-only dev, placeholder values are fine.
# Real values come from Firebase Console → Project settings → Your apps.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_PROJECT_ID=pride-born-dev
NEXT_PUBLIC_FIREBASE_API_KEY=demo-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=pride-born-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=pride-born-dev.appspot.com
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# When 1, the client SDK points at local emulators (Auth:9099, Firestore:8080, Storage:9199, Functions:5001)
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=1

# ─────────────────────────────────────────────────────────────
# Firebase — server (Admin SDK)
# Base64-encoded service account JSON. Generate with:
#   cat serviceAccount.json | base64 | tr -d '\n' | pbcopy
# In dev with emulators, this can be blank — we auto-init with project ID only.
# ─────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=

# When set locally, Admin SDK automatically routes to emulator.
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# ─────────────────────────────────────────────────────────────
# AudienceLab
# ─────────────────────────────────────────────────────────────
AUDIENCELAB_API_KEY=
AUDIENCELAB_API_URL=https://app.audiencelab.io/api/v3
AUDIENCELAB_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────
# Stripe (Phase 3)
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_OVERAGE=

# ─────────────────────────────────────────────────────────────
# Outreach (Phase 4)
# ─────────────────────────────────────────────────────────────
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# ─────────────────────────────────────────────────────────────
# Ads (Phase 5)
# ─────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────
# Observability (Phase 6)
# ─────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
